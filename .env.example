# ═══════════════════════════════════════════════════════════════════════════════
# TikTok Auto Pipeline - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control!

# ── Application ───────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
# Options: sqlite | postgresql
DB_PROVIDER=sqlite
SQLITE_DB_NAME=tiktok_pipeline.db

# PostgreSQL settings (only used if DB_PROVIDER=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=tiktok_pipeline

# ── AI / LLM Providers ────────────────────────────────────────────────────────
# Set at least one provider. The pipeline will use the configured provider
# with automatic fallback.

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-haiku-20240307

# AI Generation Parameters
AI_MAX_TOKENS=300
AI_TEMPERATURE=0.8
AI_TOP_P=0.95

# ── Scraping Configuration ────────────────────────────────────────────────────
# Virality thresholds
MIN_VIEWS=100000
MIN_VIEWS_TIMEFRAME_HOURS=24
MIN_LIKE_TO_VIEW_RATIO=0.05
MIN_SHARES=500

# Search scope
TRENDING_HASHTAGS_COUNT=10
TARGET_CREATORS=
MAX_VIDEOS_PER_RUN=5

# Rate limiting
REQUESTS_PER_MINUTE=30
REQUEST_TIMEOUT=30

# ── Video Processing ──────────────────────────────────────────────────────────
# Speed alteration (subtle)
SPEED_FACTOR=1.01
SPEED_VARIATION=0.005

# Visual mutations
MIRROR_PROBABILITY=0.5
COLOR_ADJUSTMENT_RANGE=0.02
CROP_PIXELS=2
BRIGHTNESS_ADJUSTMENT=0.01
CONTRAST_ADJUSTMENT=0.01
SATURATION_ADJUSTMENT=0.01

# Output settings
TARGET_FPS=30
FPS_VARIATION=1
OUTPUT_FORMAT=mp4
OUTPUT_QUALITY=veryfast
OUTPUT_CRF=23
AUDIO_BITRATE=128k
AUDIO_SAMPLE_RATE=44100

# ── Upload Configuration ──────────────────────────────────────────────────────
# Upload method: auto | playwright | api
UPLOAD_METHOD=auto

# Scheduling
UPLOAD_INTERVAL_MINUTES=60
RANDOMIZE_INTERVAL=true
INTERVAL_JITTER_PERCENT=20

# Browser settings (for Playwright)
HEADLESS=true
BROWSER_TYPE=chromium
# USER_DATA_DIR=/path/to/browser/profile

# Anti-detection
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720
LOCALE=en-US
TIMEZONE=America/New_York

# Video upload settings
VIDEO_DESCRIPTION_MAX_LENGTH=2200
ALLOW_DUET=true
ALLOW_STITCH=true
ALLOW_COMMENTS=everyone
VISIBILITY=public

# ── Proxy Configuration ───────────────────────────────────────────────────────
PROXY_ENABLED=true
PROXY_PROVIDER=rotating
PROXY_ROTATION_INTERVAL=300
PROXY_MAX_FAILURES=3
PROXY_VERIFY_SSL=true
PROXY_TIMEOUT=10

# Single proxy settings
# PROXY_HOST=your-proxy-host
# PROXY_PORT=8080
# PROXY_USERNAME=your-username
# PROXY_PASSWORD=your-password

# Proxy list sources
# PROXY_LIST_URL=https://your-proxy-provider.com/api/list
# PROXY_LIST_FILE=/path/to/proxy-list.txt
